{
  "name": "urabapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:vite": "vite --host",
    "dev:socket": "node server/socket-server.mjs",
    "dev:all": "node scripts/dev-with-socket.mjs",
    "start:socket": "node server/socket-server.mjs",
    "dev:open": "vite --host --open",
    "dev:loop": "node scripts/dev-keep-alive.mjs",
    "dev:free-port": "powershell -ExecutionPolicy Bypass -File scripts/dev-free-port.ps1",
    "dev:restart": "npm run dev:free-port && npm run dev",
    "prebuild": "node scripts/generate-app-version.mjs",
    "build": "vite build",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:integrations": "node scripts/verify-integrations.mjs",
    "setup:secrets": "powershell -ExecutionPolicy Bypass -File scripts/setup-integration-secrets.ps1",
    "setup:vapid": "node scripts/setup-vapid.mjs",
    "fetch:uraba-images": "node scripts/fetch-uraba-images.mjs",
    "deploy:functions": "powershell -ExecutionPolicy Bypass -File scripts/deploy-edge-functions.ps1",
    "build:sql": "node scripts/build-production-sql.mjs",
    "sync:supabase": "powershell -ExecutionPolicy Bypass -File scripts/sync-supabase.ps1",
    "sync:netlify": "powershell -ExecutionPolicy Bypass -File scripts/sync-netlify-supabase.ps1",
    "sync:vercel": "powershell -ExecutionPolicy Bypass -File scripts/sync-vercel-supabase.ps1",
    "sync:supabase-auth": "node scripts/configure-supabase-auth.mjs",
    "create:admin": "node scripts/create-admin-user.mjs",
    "create:test-users": "node scripts/create-test-users.mjs",
    "deploy:netlify": "npm run build && npx netlify deploy --prod --dir=dist",
    "deploy:vercel": "powershell -ExecutionPolicy Bypass -File scripts/deploy-vercel.ps1",
    "deploy:railway:socket": "powershell -ExecutionPolicy Bypass -File scripts/deploy-railway-socket.ps1",
    "deploy:vercel:preview": "npm run build && npx vercel deploy --yes --archive=tgz --scope catalogoivishopin",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File scripts/deploy-production.ps1",
    "deploy:netlify:preview": "npm run build && npx netlify deploy --dir=dist",
    "keep-alive:supabase": "node scripts/keep-supabase-alive.mjs --once",
    "keep-alive:supabase:loop": "node scripts/keep-supabase-alive.mjs --interval=20",
    "test:smoke": "node scripts/smoke-tests.mjs"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.17",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jiti": "^2.7.0",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.6.1",
    "motion": "^12.42.0",
    "posthog-js": "^1.393.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.9.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.3"
  }
}
